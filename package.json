{
  "name": "@hyperse/esbuild-plugin-preserve-directives",
  "version": "1.0.0",
  "description": "This plugin that preserves important directives (e.g., 'use client') at the top of output files for esbuild, tsup, etc.",
  "keywords": [
    "hyperse",
    "esbuild",
    "typescript",
    "preserve-directives",
    "use client",
    "tsup"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:hyperse-io/esbuild-plugin-preserve-directives.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "./bin/",
    "./dist/",
    "./index.js"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "lint-fix": "yarn lint --fix",
    "test": "run-s test-task",
    "test-task": "vitest run",
    "typecheck": "tsc --project ./tsconfig.json --noEmit",
    "lint-staged-files": "lint-staged --allow-empty",
    "changeset": "changeset",
    "release": "yarn build && changeset publish",
    "cz": "cz",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.5.1",
    "@changesets/cli": "2.29.4",
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@hyperse/eslint-config-hyperse": "^1.4.4",
    "@types/node": "^22.15.24",
    "@types/react": "^19.1.6",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "^9.27.0",
    "husky": "9.1.7",
    "lint-staged": "16.1.0",
    "npm-run-all": "^4.1.5",
    "react": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  },
  "packageManager": "yarn@4.9.1",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
